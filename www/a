        }
        
        if (minutesElem) {
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            minutesElem.textContent = minutes.toString().padStart(2, '0');
        }
        
        if (secondsElem) {
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);
            secondsElem.textContent = seconds.toString().padStart(2, '0');
        }
    }

    // Проверяем наличие элементов таймера
    const daysElem = document.getElementById("days");
    if (daysElem) {
        console.log('✅ Таймер найден, запускаем');
        setInterval(updateCountdown, 1000);
        updateCountdown();
    } else {
        console.log('ℹ️ Таймер не найден на странице');
    }

    // ========== СЛАЙДЕР ОТЗЫВОВ ==========
    
    const testimonials = document.querySelectorAll('.testimonial');
    const dots = document.querySelectorAll('.slider-dot');
    
    if (testimonials.length > 0 && dots.length > 0) {
        console.log(`✅ Слайдер найден: ${testimonials.length} отзывов, ${dots.length} точек`);
        
        let currentTestimonial = 0;
        let testimonialInterval;

        function showTestimonial(index) {
            // Скрываем все отзывы
            testimonials.forEach(t => {
                t.style.display = 'none';
                t.classList.remove('active');
            });
            
            // Убираем активный класс со всех точек
            dots.forEach(d => d.classList.remove('active'));
            
            // Показываем текущий отзыв
            if (testimonials[index]) {
                testimonials[index].style.display = 'block';
                testimonials[index].classList.add('active');
            }
            
            // Активируем текущую точку
            if (dots[index]) {
                dots[index].classList.add('active');
            }
            
            currentTestimonial = index;
        }

        function startTestimonialSlider() {
            testimonialInterval = setInterval(() => {
                const nextIndex = (currentTestimonial + 1) % testimonials.length;
                showTestimonial(nextIndex);
            }, 5000);
        }

        // Назначаем обработчики на точки
        dots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
                console.log(`👉 Клик на точку ${index}`);
                clearInterval(testimonialInterval);
                showTestimonial(index);
                startTestimonialSlider();
            });
        });

        // Показываем первый отзыв и запускаем слайдер
        showTestimonial(0);
        startTestimonialSlider();
        console.log('✅ Слайдер запущен');
    } else {
        console.log('ℹ️ Слайдер не найден на странице');
    }

    // ========== АНИМАЦИЯ КАРТОЧЕК ==========
    
    const characterCards = document.querySelectorAll('.character-card');
    if (characterCards.length > 0) {
        console.log(`✅ Найдено ${characterCards.length} карточек персонажей`);
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, {
            threshold: 0.1,
            rootMargin: '50px'
        });

        characterCards.forEach(card => {
            observer.observe(card);
            
            card.addEventListener('click', function() {
                const characterName = this.querySelector('h3');
                if (characterName) {
                    alert(`Подробнее о ${characterName.textContent} на странице "Герои"`);
                }
            });
        });
    }

    // ========== ОБРАБОТЧИКИ МОДАЛЬНЫХ ОКОН ==========
    
    // Кнопки открытия
    const openLoginBtn = document.getElementById('openLoginBtn');
    const openModalBtn = document.getElementById('openModalBtn');
    
    if (openLoginBtn) {
        openLoginBtn.addEventListener('click', openLoginModal);
    }
    
    if (openModalBtn) {
        openModalBtn.addEventListener('click', openRegisterModal);
    }

    // Кнопки закрытия
    const closeModalBtns = document.querySelectorAll('.close-modal, .modal-close');
    closeModalBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            console.log('❌ Клик на кнопку закрытия');
            const modal = this.closest('.modal');
            if (modal) {
                closeModal(modal);
            }
        });
    });

    // Кнопка переключения между формами
    const switchToRegister = document.getElementById('switchToRegister');
    if (switchToRegister) {
        switchToRegister.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('🔄 Переключение на регистрацию');
            
            // Закрываем окно входа
            const loginModal = document.getElementById('loginModal');
            if (loginModal) {
                closeModal(loginModal);
            }
            
            // Открываем окно регистрации
            setTimeout(() => {
                openRegisterModal();
            }, 300);
        });
    }

    // Закрытие по клику вне окна
    const modals = document.querySelectorAll('.modal');
    modals.forEach(modal => {
        modal.addEventListener('click', function(e) {
            if (e.target === this) {
                console.log('❌ Клик вне модального окна');
                closeModal(this);
            }
        });
    });

    // Закрытие по клавише ESC
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            console.log('❌ Закрытие по ESC');
            modals.forEach(modal => {
                if (modal.style.display === 'flex') {
                    closeModal(modal);
                }
            });
        }
    });

    // ========== ОБРАБОТЧИКИ ФОРМ ==========
    
    const loginForm = document.getElementById('loginForm');
    const registerForm = document.getElementById('registerForm');

    if (loginForm) {
        loginForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            console.log('📝 Отправка формы входа');
            
            const email = this.querySelector('#loginEmail').value;
            const password = this.querySelector('#loginPassword').value;
            const errorElement = this.querySelector('#loginError');

            if (!window.authService) {
                alert('❌ Система авторизации не загружена');
                return;
            }

            try {
                const result = await window.authService.login({
                    email: email,
                    password: password
                });

                alert(`🎮 С возвращением, ${result.user.username}!`);
                
                // Закрываем модальное окно
                const loginModal = document.getElementById('loginModal');
                if (loginModal) closeModal(loginModal);
                
                this.reset();
                
                // Перезагружаем страницу
                setTimeout(() => window.location.reload(), 1000);

            } catch (error) {
                console.error('❌ Ошибка входа:', error);
                if (errorElement) {
                    errorElement.textContent = error.message || 'Неверный email или пароль';
                } else {
                    alert('❌ Ошибка входа: ' + error.message);
                }
            }
        });
    }

    if (registerForm) {
        registerForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            console.log('📝 Отправка формы регистрации');
            
            const username = this.querySelector('#username').value;
            const email = this.querySelector('#email').value;
            const password = this.querySelector('#password').value;
            const confirmPassword = this.querySelector('#confirmPassword').value;
            
            // Валидация
            if (password !== confirmPassword) {
                alert('❌ Пароли не совпадают!');
                return;
            }
            
            if (password.length < 6) {
                alert('❌ Пароль должен содержать не менее 6 символов');
                return;
            }

            if (!window.authService) {
                alert('❌ Система авторизации не загружена');
                return;
            }

            try {
                const result = await window.authService.register({
                    username: username,
                    email: email,
                    password: password
                });

                alert(`🎉 Добро пожаловать в команду, ${username}!`);
                
                // Закрываем модальное окно
                const registerModal = document.getElementById('registerModal');
                if (registerModal) closeModal(registerModal);
                
                this.reset();
                
                // Перезагружаем страницу
                setTimeout(() => window.location.reload(), 1000);

            } catch (error) {
                console.error('❌ Ошибка регистрации:', error);
                alert('❌ Ошибка регистрации: ' + error.message);
            }
        });
    }

    console.log('✅ Главная страница полностью инициализирована');
});

