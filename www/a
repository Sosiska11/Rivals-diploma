// Функция для загрузки героев с сервера
async function loadHeroesFromServer() {
    try {
        console.log('Загружаем героев с сервера...');
        const response = await fetch(`${API_BASE_URL}/heroes?limit=50`);
        
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
        }
        
