// Обновленный FavoritesManager
class FavoritesManager {
    constructor() {
        this.baseURL = API_BASE_URL;
        this.favorites = new Set();
        console.log('✅ FavoritesManager инициализирован');
    }

    isUserAuthenticated() {
        return window.authService && window.authService.isAuthenticated();
    }

    getUserToken() {
        return window.authService?.token || localStorage.getItem('marvelToken');
    }

    async loadFavoritesFromDB() {
        if (!this.isUserAuthenticated()) {
            console.log('Пользователь не авторизован, пропускаем загрузку избранных');
            return;
        }

        try {
            const token = this.getUserToken();
            console.log('Загружаем избранные... Токен:', token ? 'есть' : 'нет');
            
            const response = await fetch(`${this.baseURL}/favorites`, {
                headers: { 
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) {
                throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }

            const result = await response.json();
            console.log('Ответ от сервера:', result);
            
            if (result.success && result.data && Array.isArray(result.data.favorites)) {
                this.favorites = new Set(result.data.favorites.map(fav => fav.hero_id || fav.id));
                console.log('Загруженные избранные ID:', [...this.favorites]);
            } else {
                console.warn('Неверный формат ответа:', result);
                this.favorites = new Set();
            }
            
            this.updateFavoriteButtons();
            this.updateFavoritesCount();
            
        } catch (error) {
            console.error('❌ Ошибка загрузки избранных:', error.message);
            this.favorites = new Set();
        }
    }

    async toggleFavorite(heroId, button) {
        if (!this.isUserAuthenticated()) {
            showNotification('Войдите в аккаунт чтобы добавлять героев в избранное');
            const loginBtn = document.getElementById('openLoginBtn');
            if (loginBtn) loginBtn.click();
            return;
        }

        const dbHeroId = getHeroDbIdFromName(heroId);
        const token = this.getUserToken();
        
        // Визуальная обратная связь
        button.disabled = true;
        button.style.opacity = '0.5';

        try {
            const method = this.favorites.has(dbHeroId) ? 'DELETE' : 'POST';
            
            const response = await fetch(`${this.baseURL}/favorites/${dbHeroId}`, {
                method,
                headers: { 
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }

            const result = await response.json();
            
            if (result.success) {
                if (method === 'DELETE') {
                    this.favorites.delete(dbHeroId);
                    button.classList.remove('active');
                    showNotification('Удалено из избранного');
                } else {
                    this.favorites.add(dbHeroId);
                    button.classList.add('active');
                    showNotification('Добавлено в избранное');
                }
                
                this.updateFavoritesCount();
            } else {
                throw new Error(result.message || 'Ошибка сервера');
            }
            
        } catch (error) {
            console.error('Ошибка обновления избранного:', error);
            showNotification('Ошибка: ' + error.message);
        } finally {
            button.disabled = false;
            button.style.opacity = '1';
        }
    }

    updateFavoriteButtons() {
        const favoriteBtns = document.querySelectorAll('.favorite-btn');
        const isAuthenticated = this.isUserAuthenticated();

        favoriteBtns.forEach(btn => {
            const card = btn.closest('.hero-card');
            const heroId = card.getAttribute('data-hero');
            const heroDbId = getHeroDbIdFromName(heroId);

            // Обновляем состояние кнопки
            if (this.favorites.has(heroDbId)) {
                btn.classList.add('active');
                btn.innerHTML = '♥';
                btn.title = 'Убрать из избранного';
            } else {
                btn.classList.remove('active');
                btn.innerHTML = '♡';
                btn.title = 'Добавить в избранное';
            }

            // Настройка доступности
            if (!isAuthenticated) {
                btn.style.opacity = '0.5';
                btn.disabled = true;
                btn.title = 'Войдите чтобы добавить в избранное';
            } else {
                btn.style.opacity = '1';
                btn.disabled = false;
            }
        });
    }

    updateFavoritesCount() {
        const favoritesBtn = document.querySelector('[data-filter="favorites"]');
        if (!favoritesBtn) return;

        const count = this.favorites.size;
        
        // Удаляем старый счетчик
        const oldCountSpan = favoritesBtn.querySelector('.favorites-count');
        if (oldCountSpan) oldCountSpan.remove();

        // Добавляем новый счетчик если есть избранные
        if (count > 0) {
            const countSpan = document.createElement('span');
            countSpan.className = 'favorites-count';
            countSpan.textContent = count;
            favoritesBtn.appendChild(countSpan);
        }
    }

    addFavoriteButtons() {
        const heroCards = document.querySelectorAll('.hero-card');
        heroCards.forEach(card => {
            // Проверяем, есть ли уже кнопка
            if (card.querySelector('.favorite-btn')) return;

            const favoriteBtn = document.createElement('button');
            favoriteBtn.className = 'favorite-btn';
            favoriteBtn.innerHTML = '♡';
            favoriteBtn.title = 'Добавить в избранное';
            
            favoriteBtn.onclick = (e) => {
                e.stopPropagation();
                const heroId = card.getAttribute('data-hero');
                this.toggleFavorite(heroId, favoriteBtn);
            };
            
            card.style.position = 'relative';
            card.appendChild(favoriteBtn);
        });
        
        this.updateFavoriteButtons();
    }

    clearFavorites() {
        this.favorites.clear();
        this.updateFavoriteButtons();
        this.updateFavoritesCount();
    }
}
    // Инициализируем менеджер избранного
    window.favoritesManager = new FavoritesManager();
    window.favoritesManager.addFavoriteButtons();
}

