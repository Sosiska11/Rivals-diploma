            return;
        }

        const modal = document.getElementById('postModal');
        const modalContent = document.getElementById('postModalContent');
        
        if (!modal || !modalContent) {
            console.error('❌ Модальное окно не найдено');
            return;
        }

        modalContent.innerHTML = `
