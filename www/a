    // Открытие модального окна при клике на карточку
    document.querySelectorAll('.hero-card').forEach(card => {
        card.addEventListener('click', function(e) {
            if (e.target.classList.contains('favorite-btn')) {
                return;
            }

            const heroId = this.getAttribute('data-hero');
            const hero = heroesData[heroId];
            
            if (hero) {
                document.getElementById('modalHeroName').textContent = hero.name;
                document.getElementById('modalHeroRole').textContent = hero.role;
                document.getElementById('modalHeroImage').src = hero.image;
                document.getElementById('modalHeroDesc').textContent = hero.description;
                document.getElementById('modalHeroRealName').textContent = hero.real_name;
                document.getElementById('modalHeroDifficult').textContent = hero.Difficult || 'Не указана';
                
                // Заполняем способности
                const abilitiesContainer = document.getElementById('heroAbilities');
                abilitiesContainer.innerHTML = '';
                hero.abilities.forEach(ability => {
                    const abilityItem = document.createElement('div');
                    abilityItem.className = 'ability-item';
                    abilityItem.innerHTML = `
                        <div class="ability-name">${ability.name}</div>
                        <div class="ability-desc">${ability.description}</div>
                    `;
                    abilitiesContainer.appendChild(abilityItem);
                });
                
                // Заполняем пассивные способности
                const PassAbilitiesContainer = document.getElementById('heroPassAbilities');
                PassAbilitiesContainer.innerHTML = '';
                hero.PassAbilities.forEach(PassAbility => {
                    const PassAbilityItem = document.createElement('div');
                    PassAbilityItem.className = 'PassAbility-item';
                    PassAbilityItem.innerHTML = `
                        <div class="PassAbility-name">${PassAbility.name}</div>
                        <div class="PassAbility-desc">${PassAbility.description}</div>
                    `;
                    PassAbilitiesContainer.appendChild(PassAbilityItem);
                });
                
                // Заполняем командные способности
                const TeamContainer = document.getElementById('heroTeam');
                TeamContainer.innerHTML = '';
                hero.Team.forEach(Team => {
                    const TeamItem = document.createElement('div');
                    TeamItem.className = 'Team-item';
                    TeamItem.innerHTML = `
                        <div class="Team-name">${Team.name}</div>
                        <div class="Team-desc">${Team.description}</div>
                    `;
                    TeamContainer.appendChild(TeamItem);
                });

                document.getElementById('heroModal').style.display = 'block';
                document.body.style.overflow = 'hidden';
            }
        });
    });

    // Закрытие модального окна
    document.querySelector('.modal-close').addEventListener('click', function() {
        document.getElementById('heroModal').style.display = 'none';
        document.body.style.overflow = '';
    });

    // Закрытие при клике вне окна
    window.addEventListener('click', function(event) {
        if (event.target === document.getElementById('heroModal')) {
            document.getElementById('heroModal').style.display = 'none';
            document.body.style.overflow = '';
        }
    });
}

