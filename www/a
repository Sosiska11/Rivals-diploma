function updateHeroesGrid(heroes) {
    const grid = document.querySelector('.heroes-grid');
    if (!grid || !heroes) return;
    
    // Очищаем сетку (опционально)
    // grid.innerHTML = '';
    
    // Добавляем или обновляем карточки
    heroes.forEach(hero => {
        const existingCard = document.querySelector(`.hero-card[data-hero="${hero.name.toLowerCase().replace(/\s+/g, '')}"]`);
        
        if (!existingCard) {
            // Создаем новую карточку
            createHeroCard(hero);
        }
    });
}

// Функция создания карточки героя
function createHeroCard(hero) {
    const card = document.createElement('div');
    card.className = 'hero-card visible';
    card.setAttribute('data-hero', hero.name.toLowerCase().replace(/\s+/g, ''));
    card.setAttribute('data-category', getRoleCategory(hero.role));
    
    // Определяем категорию по роли
    function getRoleCategory(role) {
        const roleMap = {
            'танк': 'tank',
            'дамагер': 'attack', 
            'стратег': 'support'
        };
        return roleMap[role] || 'attack';
    }
    
    // Формируем HTML карточки
    card.innerHTML = `
        <div class="hero-info">
            <h3 class="hero-name">${hero.name}</h3>
            <p class="hero-difficult">${getDifficultyStars(hero.difficulty)}</p>
            <p class="hero-role">${hero.role} · ${getRoleDescription(hero.role)}</p>
        </div>
    `;
    
    // Устанавливаем фоновое изображение
    if (hero.image_url) {
        card.style.backgroundImage = `url('${hero.image_url}')`;
    }
    
    // Добавляем в сетку
    const grid = document.querySelector('.heroes-grid');
    if (grid) {
        grid.appendChild(card);
    }
}

// Вспомогательные функции
function getDifficultyStars(difficulty) {
    const starMap = {
        'легкая': '★ ☆ ☆ ☆ ☆',
        'средняя': '★ ★ ☆ ☆ ☆', 
        'сложная': '★ ★ ★ ☆ ☆'
    };
    return starMap[difficulty] || '★ ☆ ☆ ☆ ☆';
}

function getRoleDescription(role) {
    const descMap = {
        'танк': 'Защита',
        'дамагер': 'Атака',
        'стратег': 'Поддержка'
    };
