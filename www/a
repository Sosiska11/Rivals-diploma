                this.addDemoPost(title, postContent.value, topic);
                postContent.value = '';
                document.getElementById('submitPostBtn').disabled = true;
                document.querySelectorAll('.tag-topic.active').forEach(tag => {
                    tag.classList.remove('active');
                });
                alert('Пост добавлен (демо-режим)!');
            }
        } catch (error) {
            console.error('❌ Ошибка сети при создании поста:', error);
            this.addDemoPost(title, postContent.value, topic);
            postContent.value = '';
            alert('Пост добавлен (демо-режим)!');
        }
    }

    addDemoPost(title, content, topic) {
        console.log('🎭 Добавление демо-поста');
        
        const newPost = {
            id: this.posts.length + 1,
            username: this.currentUser.username,
            title: title,
            content: content,
            topic: topic,
            likes: 0,
            comments: 0,
            views: 0,
            created_at: new Date().toISOString(),
            is_liked: false
        };
        
        this.posts.unshift(newPost);
        console.log('✅ Демо-пост добавлен. ID:', newPost.id);
        this.renderPosts();
    }

