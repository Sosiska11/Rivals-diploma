script community
class CommunityManager {
    constructor() {
        console.log('🆕 Создание CommunityManager');
        this.currentUser = null;
        this.posts = [];
        this.apiBase = '/api/community'; // ✅ Только путь, без .php
        this.currentFilter = 'all';
        this.currentSort = 'newest';
        
        console.log('⚙️ Настройки:', {
            apiBase: this.apiBase,
            currentUser: this.currentUser
        });
        
        this.init();
    }

    async init() {
        console.log('=== CommunityManager: Инициализация ===');
        this.checkAuth();
        this.setupEventListeners();
        await this.loadPosts();
        this.updateUserInterface();
        
        this.setDemoStats();
        this.setDemoTopPlayers();
        this.setDemoEvents();
        console.log('=== CommunityManager: Инициализация завершена ===');
    }

    checkAuth() {
        console.log('🔐 Проверка авторизации');
        const savedUser = localStorage.getItem('marvelUser');
        
        if (savedUser) {
            try {
                this.currentUser = JSON.parse(savedUser);
                console.log('✅ Пользователь найден:', this.currentUser.username);
            } catch (e) {
                console.error('❌ Ошибка парсинга пользователя:', e);
            }
        } else {
            console.log('ℹ️ Пользователь не авторизован');
        }
    }

    getAuthHeaders() {
        const token = localStorage.getItem('marvelToken');
        const headers = {
            'Content-Type': 'application/json'
        };
        
        if (token) {
            headers['Authorization'] = `Bearer ${token}`;
        }
        
        return headers;
    }

    async loadPosts(filter = 'all', sort = 'newest') {
        console.log('==========================================');
        console.log('📡 ЗАГРУЗКА ПОСТОВ');
        console.log('==========================================');
        console.log('Фильтр:', filter);
        console.log('Сортировка:', sort);
        
        // Кодируем параметры
        const filterParam = encodeURIComponent(filter);
        const sortParam = encodeURIComponent(sort);
        
        // ✅ ИСПРАВЛЕНО: без .php
        const url = `${this.apiBase}/posts?filter=${filterParam}&sort=${sortParam}`;
        
        console.log('API URL:', url);
        
        this.currentFilter = filter;
        this.currentSort = sort;
        
        const postsContainer = document.getElementById('postsContainer');
        if (postsContainer) {
            postsContainer.innerHTML = '<div class="loading-posts">Загрузка постов...</div>';
        }
        
        try {
            console.log('🚀 Отправка fetch запроса...');
            
            const response = await fetch(url, {
                headers: this.getAuthHeaders()
            });
            
            console.log('📨 Ответ получен:', response.status, response.statusText);
            
            if (!response.ok) {
                console.error('❌ Ошибка HTTP:', response.status);
                
                // Если сервер недоступен, покажем демо-посты
                if (response.status === 404) {
                    console.log('⚠️ API endpoint не найден. Показываем демо-посты.');
                    this.showDemoPosts();
                    return;
                }
                
                throw new Error(`HTTP ошибка: ${response.status}`);
            }
            
            const data = await response.json();
            
            if (data.status === 'success') {
                console.log(`✅ Получено постов: ${data.data.length}`);
                this.posts = data.data;
                console.log('💾 Посты сохранены в память');
                
                this.updateSortUI(sort);
                this.renderPosts();
            } else {
                console.error('❌ Ошибка от сервера:', data.message);
                this.showDemoPosts();
            }
            
        } catch (error) {
            console.error('❌ Ошибка сети при загрузке постов:', error);
            console.log('🎭 Показываем демо-посты из-за ошибки сети');
            this.showDemoPosts();
        }
        
        console.log('==========================================');
        console.log('🏁 ЗАГРУЗКА ПОСТОВ ЗАВЕРШЕНА');
        console.log('==========================================');
    }

    async createNewPost() {
        console.log('✍️ Создание нового поста');
        
        if (!this.currentUser) {
            alert('Войдите в аккаунт, чтобы создавать посты!');
            return;
        }

        const postContent = document.getElementById('postContent');
        if (!postContent || !postContent.value.trim()) {
            alert('Введите текст поста!');
            return;
        }

        const activeTag = document.querySelector('.tag-topic.active');
        const topic = activeTag ? activeTag.textContent : 'Обсуждение';
        const title = postContent.value.substring(0, 50) + (postContent.value.length > 50 ? '...' : '');

        console.log('📝 Данные поста:', { title, topic, contentLength: postContent.value.length });

        try {
            // ✅ ИСПРАВЛЕНО: без .php
            const response = await fetch(`${this.apiBase}/posts`, {
                method: 'POST',
                headers: this.getAuthHeaders(),
                body: JSON.stringify({
                    title: title,
                    content: postContent.value,
                    topic: topic
                })
            });
            
            console.log('📨 Ответ на создание поста:', response.status);
            
            if (response.ok) {
                const data = await response.json();
                
                if (data.status === 'success') {
                    console.log('✅ Пост создан на сервере');
                    postContent.value = '';
                    
                    const submitBtn = document.getElementById('submitPostBtn');
                    if (submitBtn) submitBtn.disabled = true;
                    
                    document.querySelectorAll('.tag-topic.active').forEach(tag => {
                        tag.classList.remove('active');
                    });

                    await this.loadPosts(this.currentFilter, this.currentSort);
                    alert('✅ Пост успешно опубликован!');
                } else {
                    alert('❌ Ошибка: ' + (data.message || 'Неизвестная ошибка'));
                }
            } else {
                throw new Error('Сервер не ответил');
            }
        } catch (error) {
            console.error('❌ Ошибка создания поста:', error);
            this.addDemoPost(title, postContent.value, topic);
            postContent.value = '';
            alert('📝 Пост добавлен (демо-режим)!');
        }
    }

    async loadComments(postId) {
        console.log('💬 Загрузка комментариев для поста ID:', postId);
        
        try {
            // ✅ ИСПРАВЛЕНО: без .php
            const response = await fetch(`${this.apiBase}/comments/${postId}`, {
                headers: this.getAuthHeaders()
            });
            
            console.log('📨 Ответ на загрузку комментариев:', response.status);
            
            if (response.ok) {
                const data = await response.json();
                
                if (data.status === 'success') {
                    console.log(`✅ Комментарии загружены: ${data.data.length} шт.`);
                    this.renderComments(postId, data.data);
                }
            }
        } catch (error) {
            console.error('❌ Ошибка загрузки комментариев:', error);
            const demoComments = [
                { 
                    username: 'IronManFan', 
                    content: 'Интересный пост! Спасибо за информацию.', 
                    created_at: new Date(Date.now() - 3600000).toISOString() 
                },
                { 
                    username: 'SpideyWeb', 
                    content: 'Полностью согласен с автором.', 
                    created_at: new Date(Date.now() - 7200000).toISOString() 
                }
            ];
            this.renderComments(postId, demoComments);
        }
    }

    async addComment(postId) {
        console.log('💬 Добавление комментария к посту ID:', postId);
        
        if (!this.currentUser) {
            alert('Войдите в аккаунт, чтобы оставлять комментарии!');
            return;
        }

        const commentText = document.getElementById('commentText');
        if (!commentText || !commentText.value.trim()) {
            alert('Введите текст комментария!');
            return;
        }

        try {
            // ✅ ИСПРАВЛЕНО: без .php
            const response = await fetch(`${this.apiBase}/comments`, {
                method: 'POST',
                headers: this.getAuthHeaders(),
                body: JSON.stringify({
                    post_id: postId,
                    content: commentText.value
                })
            });
            
            console.log('📨 Ответ на добавление комментария:', response.status);
            
            if (response.ok) {
                const data = await response.json();
                
                if (data.status === 'success') {
                    console.log('✅ Комментарий добавлен на сервер');
                    commentText.value = '';
                    
                    // Обновляем комментарии
                    await this.loadComments(postId);
                    
                    // Обновляем счетчик комментариев
                    const post = this.posts.find(p => p.id === postId);
                    if (post) {
                        post.comments += 1;
                        const postElement = document.querySelector(`.post-card[data-post-id="${postId}"]`);
                        if (postElement) {
                            const commentsCount = postElement.querySelector('.post-stat[data-action="comment"] span:last-child');
                            if (commentsCount) {
                                commentsCount.textContent = post.comments;
                            }
                        }
                    }
                    
                    alert('✅ Комментарий добавлен!');
                }
            }
        } catch (error) {
            console.error('❌ Ошибка добавления комментария:', error);
            alert('💬 Комментарий добавлен (демо-режим)!');
        }
    }

    async toggleLike(postId, element) {
        console.log('❤️ Лайк для поста ID:', postId);
        
        if (!this.currentUser) {
            alert('Войдите в аккаунт, чтобы ставить лайки!');
            return;
        }

        try {
            // ✅ ИСПРАВЛЕНО: используем /likes вместо /like.php
            const response = await fetch(`${this.apiBase}/likes`, {
                method: 'POST',
                headers: this.getAuthHeaders(),
                body: JSON.stringify({ post_id: postId })
            });
            
            console.log('📨 Ответ на лайк:', response.status);
            
            if (response.ok) {
                const data = await response.json();
                
                if (data.status === 'success') {
                    console.log('✅ Лайк обработан сервером');
                    this.updateLikeUI(element, data.data.action === 'liked');
                }
            } else {
                console.warn('⚠️ Сервер не ответил на лайк');
                this.updateLikeUI(element, !element.classList.contains('liked'));
            }
        } catch (error) {
            console.error('❌ Ошибка сети при лайке:', error);
            this.updateLikeUI(element, !element.classList.contains('liked'));
        }
    }

    updateLikeUI(element, isLiked) {
        console.log('🎨 Обновление UI лайка. Новое состояние:', isLiked);
        
        const likeCount = element.querySelector('.like-count');
        const currentLikes = parseInt(likeCount.textContent);
        
        if (isLiked) {
            element.classList.add('liked');
            likeCount.textContent = currentLikes + 1;
            console.log('👍 Лайк добавлен. Новое количество:', likeCount.textContent);
        } else {
            element.classList.remove('liked');
            likeCount.textContent = currentLikes - 1;
            console.log('👎 Лайк убран. Новое количество:', likeCount.textContent);
        }
    }

    async createNewPost() {
        console.log('✍️ Создание нового поста');
        
        if (!this.currentUser) {
