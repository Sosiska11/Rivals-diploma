    renderComments(postId, comments) {
        console.log('🎨 Отрисовка комментариев:', comments.length);
        
        const commentsList = document.getElementById(`commentsList-${postId}`);
        if (!commentsList) {
            console.error('❌ Контейнер комментариев не найден');
            return;
        }

        if (comments.length === 0) {
            console.log('ℹ️ Нет комментариев для отображения');
            commentsList.innerHTML = '<div class="no-comments">Пока нет комментариев. Будьте первым!</div>';
        } else {
            commentsList.innerHTML = comments.map(comment => `
                <div class="comment">
                    <div class="comment-author">${comment.username}</div>
                    <div class="comment-time">${this.formatTime(comment.created_at)}</div>
                    <div class="comment-text">${comment.content}</div>
                </div>
            `).join('');
            console.log('✅ Комментарии отрисованы');
        }
    }

    async addComment(postId) {
        console.log('💬 Добавление комментария к посту ID:', postId);
        
        if (!this.currentUser) {
            console.warn('⚠️ Попытка комментировать без авторизации');
            alert('Войдите в аккаунт, чтобы оставлять комментарии!');
            return;
        }

        const commentText = document.getElementById('commentText');
        if (!commentText || !commentText.value.trim()) {
            console.warn('⚠️ Пустой комментарий');
            alert('Введите текст комментария!');
            return;
        }

        try {
            const response = await fetch(`${this.apiBase}/comments.php`, {
                method: 'POST',
                headers: this.getAuthHeaders(),
                body: JSON.stringify({
                    post_id: postId,
                    content: commentText.value
                })
            });
            
            console.log('📨 Ответ на добавление комментария:', response.status);
            
            if (response.ok) {
                const text = await response.text();
                console.log('📄 Ответ сервера:', text);
                
                try {
                    const data = JSON.parse(text);
                    if (data.status === 'success') {
                        console.log('✅ Комментарий добавлен на сервер');
                        commentText.value = '';
                        
                        const newComment = {
                            username: this.currentUser.username,
                            content: commentText.value,
                            created_at: new Date().toISOString()
                        };
                        
                        const commentsList = document.getElementById(`commentsList-${postId}`);
                        if (commentsList) {
                            const commentDiv = document.createElement('div');
                            commentDiv.className = 'comment';
                            commentDiv.innerHTML = `
                                <div class="comment-author">${newComment.username}</div>
                                <div class="comment-time">Только что</div>
                                <div class="comment-text">${newComment.content}</div>
                            `;
                            commentsList.prepend(commentDiv);
                        }
                        
                        const post = this.posts.find(p => p.id === postId);
                        if (post) {
                            post.comments += 1;
                            const postElement = document.querySelector(`.post-card[data-post-id="${postId}"]`);
                            if (postElement) {
                                const commentsCount = postElement.querySelector('.post-stat[data-action="comment"] span:last-child');
                                if (commentsCount) {
                                    commentsCount.textContent = post.comments;
                                }
                            }
                        }
                    }
                } catch (e) {
                    console.error('❌ Ошибка парсинга ответа комментария:', e);
                }
            }
        } catch (error) {
            console.error('❌ Ошибка сети при добавлении комментария:', error);
            alert('Комментарий добавлен (демо-режим)!');
        }
    }

    formatTime(timestamp) {
        const date = new Date(timestamp);
        const now = new Date();
        const diff = now - date;
        
        if (diff < 60000) return 'Только что';
        if (diff < 3600000) {
            const minutes = Math.floor(diff / 60000);
            return `${minutes} мин назад`;
        }
        if (diff < 86400000) {
            const hours = Math.floor(diff / 3600000);
            return `${hours} ч назад`;
        }
        return date.toLocaleDateString('ru-RU');
    }

    getUserAvatar(username) {
        const avatarMap = {
            'n1sp1x': 'icons/avatar-default.jpg',
            'testuser': 'icons/avatar-user3.jpg',
            'admin': 'icons/avatar-user2.jpg',
            'lol': 'icons/avatar-user1.jpg',
        };
        
        const avatarFile = avatarMap[username] || 'icons/avatar-default.png';
        return avatarFile;
    }
}

