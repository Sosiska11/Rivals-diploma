            const response = await fetch(`${this.apiBase}/comments.php?post_id=${postId}`);
            
            console.log('📨 Ответ на загрузку комментариев:', response.status);
            
            if (response.ok) {
                const text = await response.text();
                console.log('📄 Ответ сервера (первые 500):', text.substring(0, 500));
                
                try {
                    const data = JSON.parse(text);
                    if (data.status === 'success') {
                        console.log(`✅ Комментарии загружены: ${data.data.length} шт.`);
